@model titans_admin.Models.ViewModels.CreateUserViewModel
@{
    ViewData["Title"] = "Create User";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-1 small">
                <li class="breadcrumb-item"><a asp-action="Index">Dashboard</a></li>
                <li class="breadcrumb-item"><a asp-action="Users">Users</a></li>
                <li class="breadcrumb-item active">Create</li>
            </ol>
        </nav>
        <h4 class="mb-0">Create User</h4>
    </div>
    <a asp-action="Users" class="btn btn-outline-secondary btn-sm">
        <i class="fas fa-arrow-left me-1"></i>Back
    </a>
</div>

<div class="row">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header">User Details</div>
            <div class="card-body">
                <form asp-action="CreateUser" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger small"></div>

                    <h6 class="text-muted mb-3">Basic Information</h6>
                    
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="FirstName" class="form-label">First Name <span class="text-danger">*</span></label>
                            <input asp-for="FirstName" class="form-control" placeholder="Enter first name">
                            <span asp-validation-for="FirstName" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="LastName" class="form-label">Last Name <span class="text-danger">*</span></label>
                            <input asp-for="LastName" class="form-control" placeholder="Enter last name">
                            <span asp-validation-for="LastName" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label">Email Address <span class="text-danger">*</span></label>
                        <input asp-for="Email" class="form-control" type="email" placeholder="user@example.com">
                        <small class="text-muted">This will be used as the login ID</small>
                        <span asp-validation-for="Email" class="text-danger small d-block"></span>
                    </div>

                    <h6 class="text-muted mb-3 mt-4">Security</h6>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="Password" class="form-label">Password <span class="text-danger">*</span></label>
                            <input asp-for="Password" class="form-control" type="password" placeholder="Minimum 6 characters">
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ConfirmPassword" class="form-label">Confirm Password <span class="text-danger">*</span></label>
                            <input asp-for="ConfirmPassword" class="form-control" type="password">
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>
                    </div>

                    <h6 class="text-muted mb-3 mt-4">Role & Status</h6>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="Role" class="form-label">Role <span class="text-danger">*</span></label>
                            <select asp-for="Role" class="form-select" asp-items="Html.GetEnumSelectList<titans_admin.Models.Enums.UserRole>()">
                                <option value="">-- Select Role --</option>
                            </select>
                            <span asp-validation-for="Role" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Status" class="form-label">Status <span class="text-danger">*</span></label>
                            <select asp-for="Status" class="form-select" asp-items="Html.GetEnumSelectList<titans_admin.Models.Enums.UserStatus>()">
                            </select>
                            <span asp-validation-for="Status" class="text-danger small"></span>
                        </div>
                    </div>

                    <h6 class="text-muted mb-3 mt-4">Contact Information</h6>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label asp-for="PhoneNumber" class="form-label">Phone Number</label>
                            <input asp-for="PhoneNumber" class="form-control" placeholder="+1-555-0100">
                            <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Address" class="form-label">Address</label>
                        <textarea asp-for="Address" class="form-control" rows="2" placeholder="Enter address"></textarea>
                    </div>

                    <div class="d-flex gap-2 pt-3 border-top">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save me-1"></i>Create User
                        </button>
                        <a asp-action="Users" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
