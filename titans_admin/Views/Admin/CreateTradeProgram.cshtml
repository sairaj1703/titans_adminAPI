@model titans_admin.Models.ViewModels.TradeProgramEditViewModel
@{
    ViewData["Title"] = "Create Trade Program";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <h1 class="h2 mb-3">Create New Trade Program</h1>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Program Details</h6>
                </div>
                <div class="card-body">
                    <form asp-action="CreateTradeProgram" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="ProgramName" class="form-label"></label>
                            <input asp-for="ProgramName" class="form-control" placeholder="e.g., Export Incentive Program 2024" />
                            <span asp-validation-for="ProgramName" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Description" class="form-label"></label>
                            <textarea asp-for="Description" class="form-control" rows="3" placeholder="Describe the program objectives and benefits"></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="ProgramType" class="form-label"></label>
                                <select asp-for="ProgramType" class="form-select">
                                    <option value="">-- Select Type --</option>
                                    <option value="Export">Export</option>
                                    <option value="Import">Import</option>
                                    <option value="Development">Development</option>
                                    <option value="Subsidy">Subsidy</option>
                                    <option value="Incentive">Incentive</option>
                                    <option value="Compliance">Compliance</option>
                                </select>
                                <span asp-validation-for="ProgramType" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="Budget" class="form-label"></label>
                                <input asp-for="Budget" class="form-control" type="number" step="0.01" placeholder="0.00" />
                                <span asp-validation-for="Budget" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="StartDate" class="form-label"></label>
                                <input asp-for="StartDate" class="form-control" type="date" />
                                <span asp-validation-for="StartDate" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="EndDate" class="form-label"></label>
                                <input asp-for="EndDate" class="form-control" type="date" />
                                <span asp-validation-for="EndDate" class="text-danger"></span>
                                <small class="text-muted">Leave blank for ongoing programs</small>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Status" class="form-label"></label>
                            <select asp-for="Status" class="form-select">
                                <option value="Active">Active</option>
                                <option value="Inactive">Inactive</option>
                                <option value="Pending">Pending</option>
                                <option value="Completed">Completed</option>
                            </select>
                            <span asp-validation-for="Status" class="text-danger"></span>
                        </div>

                        <div class="mt-4">
                            <button type="submit" class="btn btn-success">
                                <i class="fas fa-save me-2"></i>Create Program
                            </button>
                            <a asp-action="TradePrograms" class="btn btn-secondary">
                                <i class="fas fa-times me-2"></i>Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow mb-4">
                <div class="card-header py-3 bg-info text-white">
                    <h6 class="m-0 font-weight-bold">
                        <i class="fas fa-info-circle me-2"></i>Program Information
                    </h6>
                </div>
                <div class="card-body">
                    <h6 class="font-weight-bold mb-3">Creating a Trade Program</h6>
                    <p class="small">
                        Trade programs support businesses through incentives, subsidies, and development initiatives.
                    </p>
                    
                    <h6 class="font-weight-bold mb-2 mt-3">Program Types:</h6>
                    <ul class="small">
                        <li><strong>Export</strong> - Export promotion programs</li>
                        <li><strong>Import</strong> - Import facilitation</li>
                        <li><strong>Development</strong> - Business development</li>
                        <li><strong>Subsidy</strong> - Financial assistance</li>
                        <li><strong>Incentive</strong> - Performance rewards</li>
                        <li><strong>Compliance</strong> - Regulatory compliance</li>
                    </ul>

                    <h6 class="font-weight-bold mb-2 mt-3">Best Practices:</h6>
                    <ul class="small">
                        <li>Set realistic budgets</li>
                        <li>Define clear start and end dates</li>
                        <li>Regular compliance monitoring</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
