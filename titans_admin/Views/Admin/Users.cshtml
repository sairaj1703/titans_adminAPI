@model List<titans_admin.Models.ViewModels.UserListItemViewModel>
@{
    ViewData["Title"] = "Users";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="mb-1">Users</h4>
        <p class="text-muted small mb-0">Manage system users</p>
    </div>
    <a asp-action="CreateUser" class="btn btn-primary btn-sm">
        <i class="fas fa-plus me-1"></i>Add User
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success small py-2">@TempData["SuccessMessage"]</div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger small py-2">@TempData["ErrorMessage"]</div>
}

<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span>All Users</span>
        <input type="text" id="searchInput" class="form-control form-control-sm" style="max-width: 250px;" placeholder="Search...">
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0" id="usersTable">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th>Created</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var user in Model)
                        {
                            var statusClass = user.Status switch
                            {
                                titans_admin.Models.Enums.UserStatus.Active => "badge-status-active",
                                titans_admin.Models.Enums.UserStatus.Inactive => "badge-status-inactive",
                                titans_admin.Models.Enums.UserStatus.Suspended => "badge-status-suspended",
                                _ => "badge-status-pending"
                            };
                            <tr>
                                <td>@user.FullName</td>
                                <td>@user.Email</td>
                                <td><span class="badge bg-secondary">@user.Role</span></td>
                                <td><span class="badge @statusClass">@user.Status</span></td>
                                <td class="small text-muted">@user.CreatedAt.ToString("MMM dd, yyyy")</td>
                                <td class="text-end">
                                    <a asp-action="EditUser" asp-route-id="@user.UserId" class="btn btn-sm btn-outline-primary">Edit</a>
                                    <button type="button" class="btn btn-sm btn-outline-danger" onclick="confirmDelete(@user.UserId, '@user.Email')">Delete</button>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-4 text-muted">
                                No users found. <a asp-action="CreateUser">Create the first user</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('searchInput').addEventListener('keyup', function() {
            const search = this.value.toLowerCase();
            document.querySelectorAll('#usersTable tbody tr').forEach(row => {
                row.style.display = row.textContent.toLowerCase().includes(search) ? '' : 'none';
            });
        });

        function confirmDelete(id, email) {
            if (confirm('Delete user ' + email + '?')) {
                const form = document.createElement('form');
                form.method = 'POST';
                form.action = '@Url.Action("DeleteUser")';
                form.innerHTML = '<input type="hidden" name="id" value="' + id + '">' +
                    '<input type="hidden" name="__RequestVerificationToken" value="' + 
                    document.querySelector('input[name="__RequestVerificationToken"]').value + '">';
                document.body.appendChild(form);
                form.submit();
            }
        }
    </script>
}
