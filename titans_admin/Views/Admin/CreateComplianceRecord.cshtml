@model titans_admin.Models.ViewModels.ComplianceRecordEditViewModel
@{
    ViewData["Title"] = "Create Compliance Record";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var programs = ViewBag.Programs as List<titans_admin.Models.ViewModels.TradeProgramListViewModel>;
    var users = ViewBag.Users as List<titans_admin.Models.ViewModels.UserListItemViewModel>;
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12">
            <h1 class="h2 mb-3">Create Compliance Record</h1>
        </div>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card shadow mb-4">
                <div class="card-header py-3">
                    <h6 class="m-0 font-weight-bold text-primary">Compliance Review Details</h6>
                </div>
                <div class="card-body">
                    <form asp-action="CreateComplianceRecord" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="TradeProgramId" class="form-label">Trade Program</label>
                            <select asp-for="TradeProgramId" class="form-select">
                                <option value="">-- Select Program --</option>
                                @if (programs != null)
                                {
                                    foreach (var program in programs)
                                    {
                                        <option value="@program.TradeProgramId">@program.ProgramName</option>
                                    }
                                }
                            </select>
                            <span asp-validation-for="TradeProgramId" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ReviewedByUserId" class="form-label">Reviewed By (Officer)</label>
                            <select asp-for="ReviewedByUserId" class="form-select">
                                <option value="">-- Select Reviewer --</option>
                                @if (users != null)
                                {
                                    foreach (var user in users.Where(u => u.Role == titans_admin.Models.Enums.UserRole.Compliance || u.Role == titans_admin.Models.Enums.UserRole.Officer))
                                    {
                                        <option value="@user.UserId">@user.FullName (@user.Role)</option>
                                    }
                                }
                            </select>
                            <span asp-validation-for="ReviewedByUserId" class="text-danger"></span>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label asp-for="Result" class="form-label"></label>
                                <select asp-for="Result" class="form-select" asp-items="Html.GetEnumSelectList<titans_admin.Models.Enums.ComplianceResult>()">
                                    <option value="">-- Select Result --</option>
                                </select>
                                <span asp-validation-for="Result" class="text-danger"></span>
                            </div>
                            <div class="col-md-6">
                                <label asp-for="ReviewDate" class="form-label"></label>
                                <input asp-for="ReviewDate" class="form-control" type="date" />
                                <span asp-validation-for="ReviewDate" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Findings" class="form-label"></label>
                            <textarea asp-for="Findings" class="form-control" rows="3" placeholder="Describe compliance findings..."></textarea>
                            <span asp-validation-for="Findings" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Recommendations" class="form-label"></label>
                            <textarea asp-for="Recommendations" class="form-control" rows="3" placeholder="Recommendations for improvement..."></textarea>
                            <span asp-validation-for="Recommendations" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="FollowUpDate" class="form-label"></label>
                            <input asp-for="FollowUpDate" class="form-control" type="date" />
                            <span asp-validation-for="FollowUpDate" class="text-danger"></span>
                            <small class="text-muted">Optional: Set a follow-up date for non-compliant records</small>
                        </div>

                        <div class="mt-4">
                            <button type="submit" class="btn btn-success">
                                <i class="fas fa-save me-2"></i>Create Record
                            </button>
                            <a asp-action="ComplianceRecords" class="btn btn-secondary">
                                <i class="fas fa-times me-2"></i>Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow mb-4">
                <div class="card-header py-3 bg-info text-white">
                    <h6 class="m-0 font-weight-bold">
                        <i class="fas fa-info-circle me-2"></i>Compliance Review Guide
                    </h6>
                </div>
                <div class="card-body">
                    <h6 class="font-weight-bold mb-3">Creating a Compliance Record</h6>
                    <p class="small">
                        Document compliance reviews for trade programs to ensure regulatory adherence.
                    </p>
                    
                    <h6 class="font-weight-bold mb-2 mt-3">Review Results:</h6>
                    <ul class="small">
                        <li><span class="badge bg-success">Compliant</span> - Meets all requirements</li>
                        <li><span class="badge bg-danger">Non-Compliant</span> - Issues found</li>
                        <li><span class="badge bg-warning">Under Review</span> - Pending assessment</li>
                    </ul>

                    <h6 class="font-weight-bold mb-2 mt-3">Best Practices:</h6>
                    <ul class="small">
                        <li>Document all findings clearly</li>
                        <li>Provide actionable recommendations</li>
                        <li>Set follow-up dates for non-compliant items</li>
                        <li>Assign appropriate reviewers</li>
                    </ul>

                    <div class="alert alert-warning mt-3 small">
                        <i class="fas fa-exclamation-triangle me-2"></i>
                        <strong>Note:</strong> Non-compliant records will appear in the violation counter on the dashboard.
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('searchInput').addEventListener('keyup', filterRecords);
        document.getElementById('resultFilter').addEventListener('change', filterRecords);

        function filterRecords() {
            var searchInput = document.getElementById('searchInput').value.toLowerCase();
            var resultFilter = document.getElementById('resultFilter').value;
            var rows = document.querySelectorAll('#recordsTable tbody tr');
            
            rows.forEach(function(row) {
                var text = row.textContent.toLowerCase();
                var resultCell = row.cells[3].textContent;
                
                var matchesSearch = text.includes(searchInput);
                var matchesResult = resultFilter === '' || resultCell.includes(resultFilter);
                
                row.style.display = (matchesSearch && matchesResult) ? '' : 'none';
            });
        }
    </script>
}
