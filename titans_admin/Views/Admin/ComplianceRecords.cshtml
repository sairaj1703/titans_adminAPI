@model List<titans_admin.Models.ViewModels.ComplianceRecordItemViewModel>
@{
    ViewData["Title"] = "Compliance Records";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<!-- Page Header -->
<div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-4">
    <div class="mb-3 mb-md-0">
        <h1 class="h3 mb-1">
            <i class="fas fa-tasks me-2 text-primary"></i>
            Compliance Records
        </h1>
        <p class="text-muted mb-0">Track and manage compliance reviews</p>
    </div>
    <a asp-action="CreateComplianceRecord" class="btn btn-primary">
        <i class="fas fa-plus me-2"></i>Add New Record
    </a>
</div>

<!-- Alerts -->
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-circle me-2"></i>@TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- Stats Cards -->
<div class="row g-3 mb-4">
    @{
        var compliant = Model?.Count(c => c.Result == titans_admin.Models.Enums.ComplianceResult.Compliant) ?? 0;
        var nonCompliant = Model?.Count(c => c.Result == titans_admin.Models.Enums.ComplianceResult.NonCompliant) ?? 0;
        var underReview = Model?.Count(c => c.Result == titans_admin.Models.Enums.ComplianceResult.UnderReview) ?? 0;
    }
    <div class="col-6 col-lg-3">
        <div class="card stat-card success h-100">
            <div class="card-body text-center">
                <h3 class="mb-0 text-success">@compliant</h3>
                <small class="text-muted">Compliant</small>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card stat-card danger h-100">
            <div class="card-body text-center">
                <h3 class="mb-0 text-danger">@nonCompliant</h3>
                <small class="text-muted">Non-Compliant</small>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card stat-card warning h-100">
            <div class="card-body text-center">
                <h3 class="mb-0 text-warning">@underReview</h3>
                <small class="text-muted">Under Review</small>
            </div>
        </div>
    </div>
    <div class="col-6 col-lg-3">
        <div class="card stat-card primary h-100">
            <div class="card-body text-center">
                <h3 class="mb-0 text-primary">@Model?.Count</h3>
                <small class="text-muted">Total Records</small>
            </div>
        </div>
    </div>
</div>

<!-- Filter Card -->
<div class="card mb-4">
    <div class="card-body">
        <div class="row g-3">
            <div class="col-12 col-md-8">
                <div class="input-group">
                    <span class="input-group-text bg-light"><i class="fas fa-search"></i></span>
                    <input type="text" id="searchInput" class="form-control" placeholder="Search by program or reviewer...">
                </div>
            </div>
            <div class="col-12 col-md-4">
                <select id="resultFilter" class="form-select">
                    <option value="">All Results</option>
                    <option value="Compliant">Compliant</option>
                    <option value="NonCompliant">Non-Compliant</option>
                    <option value="UnderReview">Under Review</option>
                </select>
            </div>
        </div>
    </div>
</div>

<!-- Records Table -->
<div class="card">
    <div class="card-header d-flex justify-content-between align-items-center">
        <h6 class="mb-0 fw-bold"><i class="fas fa-list me-2"></i>Compliance Records</h6>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" id="recordsTable">
                <thead class="table-light">
                    <tr>
                        <th class="ps-3">Program</th>
                        <th>Result</th>
                        <th class="d-none d-md-table-cell">Review Date</th>
                        <th class="d-none d-lg-table-cell">Reviewed By</th>
                        <th class="d-none d-xl-table-cell">Findings</th>
                        <th class="text-end pe-3">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var record in Model)
                        {
                            <tr data-result="@record.Result">
                                <td class="ps-3">
                                    <span class="fw-medium">@record.ProgramName</span>
                                </td>
                                <td>
                                    @{
                                        var resultClass = record.Result switch
                                        {
                                            titans_admin.Models.Enums.ComplianceResult.Compliant => "bg-success",
                                            titans_admin.Models.Enums.ComplianceResult.NonCompliant => "bg-danger",
                                            _ => "bg-warning text-dark"
                                        };
                                        var resultIcon = record.Result switch
                                        {
                                            titans_admin.Models.Enums.ComplianceResult.Compliant => "fa-check-circle",
                                            titans_admin.Models.Enums.ComplianceResult.NonCompliant => "fa-times-circle",
                                            _ => "fa-clock"
                                        };
                                    }
                                    <span class="badge @resultClass">
                                        <i class="fas @resultIcon me-1"></i>@record.Result
                                    </span>
                                </td>
                                <td class="d-none d-md-table-cell">
                                    @record.ReviewDate.ToString("MMM dd, yyyy")
                                </td>
                                <td class="d-none d-lg-table-cell">
                                    @(record.ReviewedBy ?? "—")
                                </td>
                                <td class="d-none d-xl-table-cell">
                                    <span class="text-truncate d-inline-block" style="max-width: 200px;" title="@record.Findings">
                                        @(string.IsNullOrEmpty(record.Findings) ? "—" : 
                                          (record.Findings.Length > 50 ? record.Findings.Substring(0, 50) + "..." : record.Findings))
                                    </span>
                                </td>
                                <td class="text-end pe-3">
                                    <div class="btn-group btn-group-sm">
                                        <a asp-action="EditComplianceRecord" asp-route-id="@record.ComplianceRecordId" 
                                           class="btn btn-outline-primary" title="Edit">
                                            <i class="fas fa-edit"></i>
                                        </a>
                                        <button type="button" class="btn btn-outline-danger" 
                                                onclick="confirmDelete(@record.ComplianceRecordId)" title="Delete">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center py-5">
                                <i class="fas fa-tasks fa-3x text-muted mb-3 d-block"></i>
                                <p class="text-muted mb-3">No compliance records found</p>
                                <a asp-action="CreateComplianceRecord" class="btn btn-primary btn-sm">
                                    <i class="fas fa-plus me-1"></i>Add First Record
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('searchInput').addEventListener('keyup', filterTable);
        document.getElementById('resultFilter').addEventListener('change', filterTable);

        function filterTable() {
            const search = document.getElementById('searchInput').value.toLowerCase();
            const result = document.getElementById('resultFilter').value;
            const rows = document.querySelectorAll('#recordsTable tbody tr');

            rows.forEach(row => {
                if (!row.dataset.result) return;
                
                const text = row.textContent.toLowerCase();
                const rowResult = row.dataset.result;

                const matchesSearch = text.includes(search);
                const matchesResult = !result || rowResult === result;

                row.style.display = (matchesSearch && matchesResult) ? '' : 'none';
            });
        }

        function confirmDelete(id) {
            if (confirm('Are you sure you want to delete this compliance record?')) {
                const form = document.createElement('form');
                form.method = 'POST';
                form.action = '@Url.Action("DeleteComplianceRecord", "Admin")';

                const idInput = document.createElement('input');
                idInput.type = 'hidden';
                idInput.name = 'id';
                idInput.value = id;
                form.appendChild(idInput);

                const tokenInput = document.createElement('input');
                tokenInput.type = 'hidden';
                tokenInput.name = '__RequestVerificationToken';
                tokenInput.value = document.querySelector('input[name="__RequestVerificationToken"]').value;
                form.appendChild(tokenInput);

                document.body.appendChild(form);
                form.submit();
            }
        }
    </script>
}
