<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TradeNet Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        :root {
            --sidebar-width: 240px;
            --primary-color: #2c3e50;
            --secondary-color: #34495e;
            --accent-color: #3498db;
            --text-muted: #7f8c8d;
            --border-color: #ecf0f1;
            --bg-light: #f8f9fa;
        }
        
        * { box-sizing: border-box; }
        
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
            background-color: var(--bg-light);
            color: #333;
        }
        
        /* Sidebar */
        .sidebar {
            position: fixed;
            top: 0;
            left: 0;
            width: var(--sidebar-width);
            height: 100vh;
            background: var(--primary-color);
            z-index: 1000;
            transition: transform 0.3s ease;
        }
        
        .sidebar-header {
            padding: 1.25rem;
            border-bottom: 1px solid rgba(255,255,255,0.1);
        }
        
        .sidebar-brand {
            color: #fff;
            font-size: 1.25rem;
            font-weight: 600;
            text-decoration: none;
        }
        
        .sidebar .nav-link {
            color: rgba(255,255,255,0.7);
            padding: 0.75rem 1.25rem;
            display: flex;
            align-items: center;
            transition: all 0.2s;
            border-left: 3px solid transparent;
        }
        
        .sidebar .nav-link:hover {
            background: rgba(255,255,255,0.05);
            color: #fff;
        }
        
        .sidebar .nav-link.active {
            background: rgba(255,255,255,0.1);
            color: #fff;
            border-left-color: var(--accent-color);
        }
        
        .sidebar .nav-link i {
            width: 1.25rem;
            margin-right: 0.75rem;
        }
        
        /* Main Content */
        .main-content {
            margin-left: var(--sidebar-width);
            min-height: 100vh;
        }
        
        /* Top Navbar */
        .navbar-admin {
            background: #fff;
            border-bottom: 1px solid var(--border-color);
            padding: 0.75rem 1.5rem;
            position: sticky;
            top: 0;
            z-index: 999;
        }
        
        .content-wrapper {
            padding: 1.5rem;
        }
        
        /* Cards */
        .card {
            border: 1px solid var(--border-color);
            border-radius: 0.375rem;
            box-shadow: none;
            margin-bottom: 1rem;
        }
        
        .card-header {
            background: #fff;
            border-bottom: 1px solid var(--border-color);
            padding: 0.875rem 1rem;
            font-weight: 600;
        }
        
        /* Stat Cards */
        .stat-card {
            border-left: 3px solid var(--primary-color);
        }
        
        .stat-card .stat-value {
            font-size: 1.75rem;
            font-weight: 600;
            color: var(--primary-color);
        }
        
        .stat-card .stat-label {
            color: var(--text-muted);
            font-size: 0.875rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        
        /* Tables */
        .table th {
            background: var(--bg-light);
            border-bottom: 2px solid var(--border-color);
            font-weight: 600;
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: var(--text-muted);
        }
        
        .table td {
            vertical-align: middle;
            border-color: var(--border-color);
        }
        
        /* Buttons */
        .btn-primary {
            background: var(--primary-color);
            border-color: var(--primary-color);
        }
        
        .btn-primary:hover {
            background: var(--secondary-color);
            border-color: var(--secondary-color);
        }
        
        .btn-outline-primary {
            color: var(--primary-color);
            border-color: var(--primary-color);
        }
        
        .btn-outline-primary:hover {
            background: var(--primary-color);
            border-color: var(--primary-color);
        }
        
        /* Badges */
        .badge {
            font-weight: 500;
            padding: 0.35em 0.65em;
        }
        
        .badge-status-active { background: #27ae60; }
        .badge-status-inactive { background: #95a5a6; }
        .badge-status-pending { background: #f39c12; color: #000; }
        .badge-status-suspended { background: #e74c3c; }
        
        /* Forms */
        .form-control, .form-select {
            border-color: var(--border-color);
            border-radius: 0.25rem;
        }
        
        .form-control:focus, .form-select:focus {
            border-color: var(--accent-color);
            box-shadow: 0 0 0 0.2rem rgba(52, 152, 219, 0.15);
        }
        
        /* Alerts */
        .alert {
            border-radius: 0.25rem;
            border: none;
        }
        
        /* Auth Modal */
        .auth-modal .modal-content {
            border: none;
            border-radius: 0.5rem;
        }
        
        .auth-modal .modal-header {
            background: var(--primary-color);
            color: #fff;
            border-radius: 0.5rem 0.5rem 0 0;
        }
        
        .auth-modal .btn-close {
            filter: invert(1);
        }
        
        .user-avatar {
            width: 32px;
            height: 32px;
            background: var(--primary-color);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: #fff;
            font-weight: 600;
            font-size: 0.875rem;
        }
        
        /* Mobile */
        .sidebar-toggle {
            display: none;
            position: fixed;
            bottom: 1rem;
            right: 1rem;
            z-index: 1100;
            width: 48px;
            height: 48px;
            border-radius: 50%;
            background: var(--primary-color);
            color: #fff;
            border: none;
            box-shadow: 0 2px 8px rgba(0,0,0,0.2);
        }
        
        @@media (max-width: 991.98px) {
            .sidebar { transform: translateX(-100%); }
            .sidebar.show { transform: translateX(0); }
            .main-content { margin-left: 0; }
            .sidebar-toggle { display: flex; align-items: center; justify-content: center; }
            .sidebar-overlay {
                display: none;
                position: fixed;
                top: 0; left: 0; right: 0; bottom: 0;
                background: rgba(0,0,0,0.4);
                z-index: 999;
            }
            .sidebar-overlay.show { display: block; }
        }
        
        @@media (max-width: 575.98px) {
            .content-wrapper { padding: 1rem; }
        }
    </style>
</head>
<body>
    <div class="sidebar-overlay" id="sidebarOverlay" onclick="toggleSidebar()"></div>
    
    <!-- Sidebar -->
    <nav class="sidebar" id="sidebar">
        <div class="sidebar-header">
            <a href="@Url.Action("Index", "Admin")" class="sidebar-brand">
                <i class="fas fa-shield-alt me-2"></i>TradeNet
            </a>
            <div class="small text-white-50 mt-1">Administration</div>
        </div>
        
        <ul class="nav flex-column mt-3">
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")" 
                   asp-controller="Admin" asp-action="Index">
                    <i class="fas fa-home"></i><span>Dashboard</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(new[] { "Users", "CreateUser", "EditUser" }.Contains(ViewContext.RouteData.Values["action"]?.ToString()) ? "active" : "")" 
                   asp-controller="Admin" asp-action="Users">
                    <i class="fas fa-users"></i><span>Users</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(new[] { "TradeLicenses", "CreateTradeLicense", "EditTradeLicense" }.Contains(ViewContext.RouteData.Values["action"]?.ToString()) ? "active" : "")" 
                   asp-controller="Admin" asp-action="TradeLicenses">
                    <i class="fas fa-file-alt"></i><span>Trade Licenses</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(new[] { "TradePrograms", "CreateTradeProgram", "EditTradeProgram" }.Contains(ViewContext.RouteData.Values["action"]?.ToString()) ? "active" : "")" 
                   asp-controller="Admin" asp-action="TradePrograms">
                    <i class="fas fa-briefcase"></i><span>Trade Programs</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(new[] { "ComplianceRecords", "CreateComplianceRecord", "EditComplianceRecord" }.Contains(ViewContext.RouteData.Values["action"]?.ToString()) ? "active" : "")" 
                   asp-controller="Admin" asp-action="ComplianceRecords">
                    <i class="fas fa-clipboard-check"></i><span>Compliance</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "AuditLogs" ? "active" : "")" 
                   asp-controller="Admin" asp-action="AuditLogs">
                    <i class="fas fa-history"></i><span>Audit Logs</span>
                </a>
            </li>
        </ul>
    </nav>

    <!-- Main Content -->
    <main class="main-content">
        <nav class="navbar navbar-admin">
            <div class="container-fluid">
                <div class="d-flex align-items-center">
                    <button class="btn btn-link d-lg-none p-0 me-3 text-dark" onclick="toggleSidebar()">
                        <i class="fas fa-bars"></i>
                    </button>
                    <span class="d-none d-md-inline text-muted small">
                        @DateTime.Now.ToString("dddd, MMMM dd, yyyy")
                    </span>
                </div>
                
                <div class="d-flex align-items-center gap-2">
                    <div class="auth-buttons" id="authButtons">
                        <button class="btn btn-outline-primary btn-sm" data-bs-toggle="modal" data-bs-target="#loginModal">
                            <i class="fas fa-sign-in-alt me-1"></i>Login
                        </button>
                        <button class="btn btn-primary btn-sm ms-2" data-bs-toggle="modal" data-bs-target="#registerModal">
                            <i class="fas fa-user-plus me-1"></i>Register
                        </button>
                    </div>
                    
                    <div class="dropdown d-none" id="userDropdown">
                        <button class="btn btn-link p-0 dropdown-toggle text-dark text-decoration-none" type="button" data-bs-toggle="dropdown">
                            <div class="d-flex align-items-center">
                                <div class="user-avatar me-2"><span id="userInitial">A</span></div>
                                <span class="d-none d-md-inline" id="userName">User</span>
                            </div>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><span class="dropdown-item-text small text-muted" id="userEmailDisplay">user@example.com</span></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item" href="#" onclick="logout()"><i class="fas fa-sign-out-alt me-2"></i>Logout</a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </nav>

        <div class="content-wrapper">
            @RenderBody()
        </div>
    </main>

    <button class="sidebar-toggle" onclick="toggleSidebar()"><i class="fas fa-bars"></i></button>

    <!-- Login Modal -->
    <div class="modal fade auth-modal" id="loginModal" tabindex="-1" data-bs-backdrop="static">
        <div class="modal-dialog modal-dialog-centered modal-sm">
            <div class="modal-content">
                <div class="modal-header">
                    <h6 class="modal-title"><i class="fas fa-sign-in-alt me-2"></i>Sign In</h6>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="loginForm" onsubmit="return handleLogin(event)">
                        <div id="loginError" class="alert alert-danger py-2 small d-none"></div>
                        <div class="mb-3">
                            <label class="form-label small">Email Address</label>
                            <input type="email" class="form-control" id="loginEmail" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small">Password</label>
                            <input type="password" class="form-control" id="loginPassword" required>
                        </div>
                        <button type="submit" class="btn btn-primary w-100" id="loginBtn">Sign In</button>
                    </form>
                    <div class="text-center mt-3">
                        <small class="text-muted">Don't have an account? <a href="#" onclick="switchToRegister()">Register</a></small>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Register Modal -->
    <div class="modal fade auth-modal" id="registerModal" tabindex="-1" data-bs-backdrop="static">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h6 class="modal-title"><i class="fas fa-user-plus me-2"></i>Create Account</h6>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <form id="registerForm" onsubmit="return handleRegister(event)">
                        <div id="registerError" class="alert alert-danger py-2 small d-none"></div>
                        <div id="registerSuccess" class="alert alert-success py-2 small d-none"></div>
                        <div class="row mb-3">
                            <div class="col-6">
                                <label class="form-label small">First Name</label>
                                <input type="text" class="form-control" id="registerFirstName" required>
                            </div>
                            <div class="col-6">
                                <label class="form-label small">Last Name</label>
                                <input type="text" class="form-control" id="registerLastName" required>
                            </div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small">Email Address</label>
                            <input type="email" class="form-control" id="registerEmail" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label small">User Type</label>
                            <select class="form-select" id="registerRole" required>
                                <option value="">-- Select User Type --</option>
                                <option value="Business">Business / Trader</option>
                                <option value="Officer">Trade Officer</option>
                                <option value="Manager">Program Manager</option>
                                <option value="Compliance">Compliance Officer</option>
                                <option value="Auditor">Government Auditor</option>
                            </select>
                        </div>
                        <div class="row mb-3">
                            <div class="col-6">
                                <label class="form-label small">Password</label>
                                <input type="password" class="form-control" id="registerPassword" required minlength="6">
                            </div>
                            <div class="col-6">
                                <label class="form-label small">Confirm</label>
                                <input type="password" class="form-control" id="registerConfirmPassword" required>
                            </div>
                        </div>
                        <button type="submit" class="btn btn-primary w-100" id="registerBtn">Create Account</button>
                    </form>
                    <div class="text-center mt-3">
                        <small class="text-muted">Already have an account? <a href="#" onclick="switchToLogin()">Sign In</a></small>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <form id="__AjaxAntiForgeryForm" action="#" method="post">@Html.AntiForgeryToken()</form>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function toggleSidebar() {
            document.getElementById('sidebar').classList.toggle('show');
            document.getElementById('sidebarOverlay').classList.toggle('show');
        }

        function switchToRegister() {
            bootstrap.Modal.getInstance(document.getElementById('loginModal')).hide();
            setTimeout(() => new bootstrap.Modal(document.getElementById('registerModal')).show(), 200);
        }

        function switchToLogin() {
            bootstrap.Modal.getInstance(document.getElementById('registerModal')).hide();
            setTimeout(() => new bootstrap.Modal(document.getElementById('loginModal')).show(), 200);
        }

        function handleLogin(e) {
            e.preventDefault();
            const email = document.getElementById('loginEmail').value;
            const password = document.getElementById('loginPassword').value;
            const btn = document.getElementById('loginBtn');
            const err = document.getElementById('loginError');
            
            btn.disabled = true;
            btn.textContent = 'Signing in...';
            err.classList.add('d-none');

            $.ajax({
                url: '@Url.Action("Login", "Auth")',
                type: 'POST',
                contentType: 'application/json',
                headers: { 'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val() },
                data: JSON.stringify({ email, password }),
                success: function(r) {
                    if (r.success) {
                        sessionStorage.setItem('user', JSON.stringify(r.user));
                        showLoggedInState(r.user);
                        bootstrap.Modal.getInstance(document.getElementById('loginModal')).hide();
                        document.getElementById('loginForm').reset();
                    } else {
                        err.textContent = r.message || 'Invalid credentials';
                        err.classList.remove('d-none');
                    }
                },
                error: function() { err.textContent = 'Error occurred'; err.classList.remove('d-none'); },
                complete: function() { btn.disabled = false; btn.textContent = 'Sign In'; }
            });
            return false;
        }

        function handleRegister(e) {
            e.preventDefault();
            const data = {
                firstName: document.getElementById('registerFirstName').value,
                lastName: document.getElementById('registerLastName').value,
                email: document.getElementById('registerEmail').value,
                role: document.getElementById('registerRole').value,
                password: document.getElementById('registerPassword').value,
                confirmPassword: document.getElementById('registerConfirmPassword').value
            };
            const btn = document.getElementById('registerBtn');
            const err = document.getElementById('registerError');
            const suc = document.getElementById('registerSuccess');

            if (!data.role) {
                err.textContent = 'Please select a user type';
                err.classList.remove('d-none');
                return false;
            }

            if (data.password !== data.confirmPassword) {
                err.textContent = 'Passwords do not match';
                err.classList.remove('d-none');
                return false;
            }

            btn.disabled = true;
            btn.textContent = 'Creating...';
            err.classList.add('d-none');
            suc.classList.add('d-none');

            $.ajax({
                url: '@Url.Action("Register", "Auth")',
                type: 'POST',
                contentType: 'application/json',
                headers: { 'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val() },
                data: JSON.stringify(data),
                success: function(r) {
                    if (r.success) {
                        suc.textContent = r.message || 'Account created!';
                        suc.classList.remove('d-none');
                        document.getElementById('registerForm').reset();
                        setTimeout(() => switchToLogin(), 2000);
                    } else {
                        err.textContent = r.message || 'Registration failed';
                        err.classList.remove('d-none');
                    }
                },
                error: function() { err.textContent = 'Error occurred'; err.classList.remove('d-none'); },
                complete: function() { btn.disabled = false; btn.textContent = 'Create Account'; }
            });
            return false;
        }

        function showLoggedInState(user) {
            document.getElementById('authButtons').classList.add('d-none');
            document.getElementById('userDropdown').classList.remove('d-none');
            var initial = user.firstName ? user.firstName.charAt(0) : user.email.charAt(0);
            document.getElementById('userInitial').textContent = initial.toUpperCase();
            var displayName = user.firstName || user.email.split('@@')[0];
            document.getElementById('userName').textContent = displayName;
            document.getElementById('userEmailDisplay').textContent = user.email;
        }

        function logout() {
            sessionStorage.removeItem('user');
            document.getElementById('authButtons').classList.remove('d-none');
            document.getElementById('userDropdown').classList.add('d-none');
            $.post('@Url.Action("Logout", "Auth")');
        }

        document.addEventListener('DOMContentLoaded', function() {
            const user = sessionStorage.getItem('user');
            if (user) showLoggedInState(JSON.parse(user));
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
