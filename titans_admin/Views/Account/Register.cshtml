@{
    ViewData["Title"] = "Register";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        <div class="text-center mb-4">
            <h3>Create Account</h3>
            <p class="text-muted">Fill in the details below to register</p>
        </div>

        <div class="card">
            <div class="card-header">Registration Details</div>
            <div class="card-body">
                <form id="registerForm">
                    <div id="validationSummary" class="alert alert-danger small d-none"></div>

                    <h6 class="text-muted mb-3">Basic Information</h6>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">First Name <span class="text-danger">*</span></label>
                            <input type="text" name="FirstName" class="form-control" placeholder="Enter first name" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Last Name <span class="text-danger">*</span></label>
                            <input type="text" name="LastName" class="form-control" placeholder="Enter last name" required>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Email Address <span class="text-danger">*</span></label>
                        <input type="email" name="Email" class="form-control" placeholder="user@example.com" required>
                        <small class="text-muted">This will be used as your login ID</small>
                    </div>

                    <h6 class="text-muted mb-3 mt-4">Security</h6>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Password <span class="text-danger">*</span></label>
                            <input type="password" name="Password" class="form-control" placeholder="Minimum 6 characters" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Confirm Password <span class="text-danger">*</span></label>
                            <input type="password" name="ConfirmPassword" class="form-control" placeholder="Re-enter password" required>
                        </div>
                    </div>

                    <h6 class="text-muted mb-3 mt-4">Account Type</h6>

                    <div class="mb-3">
                        <label class="form-label">User Type <span class="text-danger">*</span></label>
                        <select name="Role" class="form-select" required>
                            <option value="">-- Select User Type --</option>
                            <option value="Business">Business / Trader</option>
                            <option value="Officer">Trade Officer</option>
                            <option value="Manager">Program Manager</option>
                            <option value="Compliance">Compliance Officer</option>
                            <option value="Auditor">Government Auditor</option>
                        </select>
                    </div>

                    <h6 class="text-muted mb-3 mt-4">Contact Information (Optional)</h6>

                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label">Phone Number</label>
                            <input type="tel" name="PhoneNumber" class="form-control" placeholder="+1-555-0100">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Address</label>
                            <input type="text" name="Address" class="form-control" placeholder="Enter address">
                        </div>
                    </div>

                    <div class="d-grid gap-2 pt-3 border-top">
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-user-plus me-1"></i>Register
                        </button>
                        <a href="/" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>

        <div class="text-center mt-3">
            <p class="text-muted">Already have an account? <a href="/Account/Login">Login here</a></p>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('registerForm').addEventListener('submit', async function(e) {
            e.preventDefault();

            const form = e.target;
            const formData = new FormData(form);
            const data = {
                email: formData.get('Email'),
                firstName: formData.get('FirstName'),
                lastName: formData.get('LastName'),
                password: formData.get('Password'),
                confirmPassword: formData.get('ConfirmPassword'),
                role: formData.get('Role'),
                phoneNumber: formData.get('PhoneNumber'),
                address: formData.get('Address')
            };

            const validationDiv = document.getElementById('validationSummary');
            validationDiv.classList.add('d-none');

            try {
                const response = await fetch('/Auth/Register', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });

                const result = await response.json();

                if (result.success) {
                    alert(result.message);
                    window.location.href = '/Account/Login';
                } else {
                    validationDiv.textContent = result.message;
                    validationDiv.classList.remove('d-none');
                }
            } catch (error) {
                validationDiv.textContent = 'An error occurred. Please try again.';
                validationDiv.classList.remove('d-none');
            }
        });
    </script>
}
